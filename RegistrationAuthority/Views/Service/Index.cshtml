@model RegistrationAuthority.Models.ServiceModel

@{
    ViewData["Title"] = "Index";
}

    <div class="bs-component">
        <div class="alert  bg-gradient-primary text-dark">
            <strong>Services</strong>
        </div>
    </div>
<div class="container-fluid row">
    <div class="col-sm-2"></div>
    <div class="col-sm-8">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group card-header bg-gradient-secondary row text-dark">
                <div class="col-sm-2"><label asp-for="Serial" class="control-label " style="font-weight:bold;"></label></div>
                <div class="col-sm-10  "><input asp-for="Serial" class="form-control" /></div>
                <span asp-validation-for="Serial" class="text-danger"></span>
            </div>
            <div class="form-group card-header bg-gradient-secondary row text-dark">
                <div class="col-sm-2 "> <label asp-for="Password" class="control-label" style="font-weight:bold;"></label></div>
                <div class="col-sm-10 "> <input asp-for="Password" class="form-control" /></div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-group card-header bg-gradient-secondary row text-dark">
                <div class="col-sm-2 "> <label asp-for="Object" class="control-label" style="font-weight:bold;"></label></div>
                <div class="col-sm-10 ">
                    <select asp-for="Object" asp-items="Model.Objects" class="form-control" id="obj">
                    </select>
                </div>
                <span asp-validation-for="Object" class="text-danger"></span>
            </div>
            <div class="card-header bg-gradient-secondary row text-dark" id="reas">
                <div class="col-sm-2 "> <label asp-for="Reason" class="control-label" style="font-weight:bold;"></label></div>
                <div class="col-sm-10 ">
                    <select asp-for="Reason" asp-items="Model.Reasons" class="form-control">
                    </select>
                </div>
                <span asp-validation-for="Reason" class="text-danger"></span>
            </div>
            <div class="card-header bg-gradient-primary row text-dark">
               <input type="submit" value="Create" class="btn btn-success" />
            </div>
        </form>
    </div>
</div>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script type="text/javascript">
    $(document).ready(function () {
        $('#reas').hide();
    });
    $("#obj").change(function () {
        var val = $("#obj").val();

        if (val == "Revoke") {
            $('#reas').show();
        }
        else {
            $('#reas').hide();
        }

    });
    </script>
}



