
@{
    ViewData["Title"] = "Index";
}

<div id="carouselExampleIndicators" class="carousel slide" data-ride="carousel">
    <ol class="carousel-indicators">
        <li data-target="#carouselExampleIndicators" data-slide-to="0" class="active"></li>
        <li data-target="#carouselExampleIndicators" data-slide-to="1"></li>

    </ol>
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img class="d-block w-100" src="~/images/cover.jpg" alt="First slide">
            <div class="carousel-caption d-none d-md-block">
                <input type="button" value="Creat Certificate" class="btn btn-primary" id="Creat" />


            </div>
        </div>
        <div class="carousel-item">
            <img class="d-block w-100" src="~/images/cover.jpg" alt="Second slide">
            <div class="carousel-caption d-none d-md-block">
                <input type="button" value="Upload Certificate" class="btn btn-primary" />
            </div>
        </div>

    </div>
    <a class="carousel-control-prev" href="#carouselExampleIndicators" role="button" data-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="sr-only">Previous</span>
    </a>
    <a class="carousel-control-next" href="#carouselExampleIndicators" role="button" data-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="sr-only">Next</span>
    </a>
</div>
@section Scripts {
    <script type="text/javascript">
        $('.carousel').carousel({
            interval: 2000
        });

        $("#Creat").click(function () {
            window.location.href = '/Csr/Create'

        });
    </script>
}
