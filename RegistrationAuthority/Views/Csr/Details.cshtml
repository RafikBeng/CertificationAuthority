@model RegistrationAuthority.Models.CsrModel

@{
    ViewData["Title"] = "Details";
}

    <div class="bs-component">
        <div class="alert  bg-gradient-primary text-dark">
            <strong>CSR Details</strong>
        </div>
    </div>
    <div class="container">
        <table class="table  table-responsive-sm table-hover text-dark">

            <tbody>
                <tr>
                    <th scope="row" class="bg-gradient-primary">Distinguished Name</th>
                    <td class="bg-gradient-secondary">
                        @Html.DisplayFor(model => model.SubjectDN)
                    </td>

                </tr>



                <tr>
                    <th scope="row" class="bg-gradient-primary">Signature Algorithm</th>
                    <td class="bg-gradient-secondary">
                        @Html.DisplayFor(model => model.Signature)
                    </td>


                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-primary">Public key Algorithm</th>
                    <td class="bg-gradient-secondary">
                        @Html.DisplayFor(model => model.Algorithme)
                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-primary">key Size</th>
                    <td class="bg-gradient-secondary">
                        @Html.DisplayFor(model => model.KeySize)
                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-primary">Thumbprint</th>
                    <td class="bg-gradient-secondary">

                        <TEXTAREA rows="5" cols="30" readonly class="form-control text-monospace bg-success">@Html.DisplayFor(model => model.Thumbprint)</TEXTAREA>

                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-primary">Public Key</th>
                    <td class="bg-gradient-secondary">

                        <TEXTAREA rows="12" cols="30" readonly class="form-control text-monospace bg-success" id="public">@Html.DisplayFor(model => model.Publickey)</TEXTAREA>
                        <input type="button" class="btn btn-danger" value="Save .pem" onclick="location.href='@Url.Action("Download_PEM_Public", "Csr", new { id = Model.Id })'" />
                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-primary">Private Key</th>
                    <td class="bg-gradient-secondary">

                        <TEXTAREA rows="12" cols="30" readonly class="form-control text-monospace bg-success" id="private">@Html.DisplayFor(model => model.Privatekey)</TEXTAREA>
                        <input type="button" class="btn btn-danger" value="Save .pem" onclick="location.href='@Url.Action("Download_PEM_Private", "Csr", new { id = Model.Id })'" />
                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-primary">Extensions</th>
                    <td class="bg-gradient-secondary">

                        <TEXTAREA rows="12" cols="30" readonly class="form-control text-monospace bg-success">@Html.DisplayFor(model => model.Extensions)</TEXTAREA>

                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-primary">CSR</th>
                    <td class="bg-gradient-secondary">

                        <TEXTAREA rows="12" cols="30" readonly class="form-control text-monospace bg-success" id="csr">@Html.DisplayFor(model => model.Certificat)</TEXTAREA>
                        <input type="button" class="btn btn-danger" value="Save .pem" onclick="location.href='@Url.Action("Download_PEM", "Csr", new { id = Model.Id })'" />
                        <input type="button" class="btn btn-warning" value="Save .csr" onclick="location.href='@Url.Action("Download", "Csr", new { id = Model.Id })'" />
                    </td>

                </tr>
            </tbody>
        </table>
    </div>

