@model Certificationauthority.Models.CertModel

@{
    ViewData["Title"] = "Details";
}


    <div class="container">
        <h1>CRS Details</h1>
        <table class="table  table-responsive-sm">

            <tbody>

                <tr>
                    <th scope="row" class="bg-gradient-success">Distinguished Name</th>
                    <td class="bg-gradient-success">
                        @Html.DisplayFor(model => model.SubjectDN)
                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-success">Validity</th>
                    <td class="bg-gradient-success">
                        @Html.DisplayFor(model => model.Validity)
                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-success">Signature Algorithm</th>
                    <td class="bg-gradient-success">
                        @Html.DisplayFor(model => model.Signature)
                    </td>


                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-success">Public key Algorithm</th>
                    <td class="bg-gradient-success">
                        @Html.DisplayFor(model => model.Algorithme)
                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-success">key Size</th>
                    <td class="bg-gradient-success">
                        @Html.DisplayFor(model => model.KeySize)
                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-success">Thumbprint</th>
                    <td class="bg-gradient-success">

                        <TEXTAREA  rows="5" cols="30" readonly class="form-control text-monospace bg-gradient-info">@Html.DisplayFor(model => model.Thumbprint)</TEXTAREA>
                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-success">Public Key</th>
                    <td class="bg-gradient-success">
                        <TEXTAREA  rows="12" cols="30" readonly class="form-control text-monospace bg-gradient-info">@Html.DisplayFor(model => model.Publickey)</TEXTAREA>

                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-success">Private Key</th>
                    <td class="bg-gradient-success">
                        <TEXTAREA  rows="12" cols="30" readonly class="form-control text-monospace bg-gradient-info">@Html.DisplayFor(model => model.Privatekey)</TEXTAREA>

                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-success">Extensions</th>
                    <td class="bg-gradient-success">
                        <TEXTAREA  rows="12" cols="30" readonly class="form-control text-monospace bg-gradient-info">@Html.DisplayFor(model => model.Extensions)</TEXTAREA>

                    </td>

                </tr>
                <tr>
                    <th scope="row" class="bg-gradient-success">Certificate</th>
                    <td class="bg-gradient-success">
                        <TEXTAREA  rows="12" cols="30" readonly class="form-control text-monospace bg-gradient-info">@Html.DisplayFor(model => model.Certificat)</TEXTAREA>

                    </td>

                </tr>
            </tbody>
        </table>
    </div>
    <div class="container card-header">
        <input type="button" class="btn btn-success" value="Validate" onclick="location.href='@Url.Action("Validate", "Csr", new { id = Model.Id })'" />
        <input type="button" class="btn btn-warning" value="Delete" onclick="location.href='@Url.Action("Delete", "Csr", new { id = Model.Id })'" />
    </div>
