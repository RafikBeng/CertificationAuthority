@model Certificationauthority.Models.CrlModel

@{
    ViewData["Title"] = "Validate_Crl";
}

<h1>Validate_Crl</h1>

<div class="container">

    <table class="table table-striped table-dark">

        <tbody>
            <tr>
                <th scope="row">Serial Number</th>
                <td>
                    @Html.DisplayFor(model => model.Serial)
                </td>

            </tr>

            <tr>
                <th scope="row">Issuer Distinguished Name</th>
                <td>
                    @Html.DisplayFor(model => model.DN)
                </td>

            </tr>
            <tr>
                <th scope="row">This Update</th>
                <td>
                    @Html.DisplayFor(model => model.ThisUpdate)
                </td>

            </tr>
            <tr>
                <th scope="row">Next Update</th>
                <td>
                    @Html.DisplayFor(model => model.NextUpdate)
                </td>

            </tr>

            <tr>
                <th scope="row">Crl</th>
                <td>
                    <TEXTAREA wrap="hard" rows="12" cols="30" readonly class="form-control text-monospace">@Html.DisplayFor(model => model.Content)</TEXTAREA>

                </td>

            </tr>
        </tbody>
    </table>
</div>
<div>
    <a asp-action="Index">Back to List</a>
</div>
