@model IEnumerable<Certificationauthority.Models.ServiceModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>


<div class="container">
    <table class="table table-striped table-dark">
        <thead>
            <tr>

                <th>
                    @Html.DisplayNameFor(model => model.Serial)
                </th>
               
                <th>
                    @Html.DisplayNameFor(model => model.Object)
                </th>
               
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
            <tr>

                <td>
                    @Html.DisplayFor(modelItem => item.Serial)
                </td>
              
                <td>
                    @Html.DisplayFor(modelItem => item.Object)
                </td>
                
                <td>

                    @Html.ActionLink("Details", "Details", new { Serial = item.Serial })

                </td>
            </tr>
            }
        </tbody>
    </table>
</div>

